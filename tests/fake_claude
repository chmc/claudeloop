  # Produces raw.json compatible with rec_extract_tool_calls() is_error extraction.
  default_exit=0
  printf '{"type":"system","subtype":"init","model":"fake-claude-v1"}\n'
  printf '{"type":"assistant","message":{"content":[{"type":"tool_use","id":"toolu_sr01","name":"Read","input":{"file_path":"src/main.sh"}}]}}\n'
