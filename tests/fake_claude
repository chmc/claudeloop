#!/bin/sh
# Fake Claude CLI for testing and verification.
# Compatible with: claude-code v2.1.71 (checked 2026-03-08)
#
# Emits realistic stream-json events without API calls.
# Configuration via $FAKE_CLAUDE_DIR (required).
#
# Files:
#   scenario         - default scenario name (default: success)
#   scenarios        - per-call scenario (line N = call N, overrides default)
#   exit_codes       - per-call exit code (line N = call N)
#   call_count       - auto-incremented call counter
#   prompts/prompt_N - captured stdin for call N
#   args/args_N      - captured CLI args for call N
#   custom_output    - extra lines for custom scenario
#   custom_output_N  - per-call custom output
#
# Auto-detection: success, success_multi, and success_realistic scenarios
# auto-detect AI-parse and verification prompts from stdin content.
# AI-parse prompts (containing "plan extraction assistant") emit phase headers.
# Verification prompts (containing "verif") emit VERIFICATION_PASSED.

FAKE_CLAUDE_DIR="${FAKE_CLAUDE_DIR:?FAKE_CLAUDE_DIR must be set}"

# --- Call counting & capture ---
count=$(cat "$FAKE_CLAUDE_DIR/call_count" 2>/dev/null || echo 0)
count=$((count + 1))
printf '%s' "$count" > "$FAKE_CLAUDE_DIR/call_count"

mkdir -p "$FAKE_CLAUDE_DIR/prompts" "$FAKE_CLAUDE_DIR/args"

# Detect stream-json input format (bidirectional stdio protocol)
_stream_json_input=false
for _arg in "$@"; do
  case "$_arg" in
    --input-format) _stream_json_input=true ;;
    stream-json) ;; # handled by prior flag
    --permission-prompt-tool) ;; # accept but ignore
    stdio) ;; # accept but ignore
  esac
done

if [ "$_stream_json_input" = "true" ]; then
  # Read stream-json message from stdin (one line of JSON, don't wait for EOF)
  IFS= read -r _raw_input 2>/dev/null || _raw_input=""
  printf '%s' "$_raw_input" > "$FAKE_CLAUDE_DIR/prompts/prompt_$count"
else
  cat > "$FAKE_CLAUDE_DIR/prompts/prompt_$count"
fi
printf '%s\n' "$@" > "$FAKE_CLAUDE_DIR/args/args_$count"

# --- Scenario selection ---
scenario=""
if [ -f "$FAKE_CLAUDE_DIR/scenarios" ]; then
  scenario=$(sed -n "${count}p" "$FAKE_CLAUDE_DIR/scenarios" 2>/dev/null)
fi
[ -z "$scenario" ] && scenario=$(cat "$FAKE_CLAUDE_DIR/scenario" 2>/dev/null)
[ -z "$scenario" ] && scenario="success"

# --- Prompt auto-detection ---
# Detects claudeloop's AI-parse and verification prompts from captured stdin.
# Used by success/success_multi/success_realistic to emit appropriate responses
# instead of the default tool_use output.

is_ai_parse_prompt() {
  # Matches ai_parse_plan() prompt in lib/ai_parser.sh
  local prompt_file="$FAKE_CLAUDE_DIR/prompts/prompt_$count"
  [ -f "$prompt_file" ] && grep -q 'plan extraction assistant' "$prompt_file"
}

is_verify_prompt() {
  # Matches ai_verify_plan() prompt in lib/ai_parser.sh (plan-level verification)
  local prompt_file="$FAKE_CLAUDE_DIR/prompts/prompt_$count"
  [ -f "$prompt_file" ] && grep -q 'DECOMPOSED' "$prompt_file"
}

is_phase_verify_prompt() {
  # Matches verify_phase() in lib/verify.sh (per-phase verification)
  local prompt_file="$FAKE_CLAUDE_DIR/prompts/prompt_$count"
  [ -f "$prompt_file" ] && grep -qi 'verification' "$prompt_file"
}

# --- Scenario functions ---
# Each emits hardcoded NDJSON matching the real Claude CLI stream-json format.
# Success scenarios auto-detect AI-parse and verification prompts.

scenario_ai_parse() {
  # Emits ## Phase headers like a real AI plan extraction response.
  # Used directly as "ai_parse" scenario or auto-dispatched from success scenarios.
  default_exit=0
  printf '{"type":"system","subtype":"init","model":"fake-claude-v1"}\n'
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"## Phase 1: Setup\\nSet up the project structure and dependencies.\\n\\n## Phase 2: Implementation\\nImplement the core feature.\\n"}]}}\n'
  printf '{"type":"result","total_cost_usd":0.01,"duration_ms":2000,"num_turns":1,"usage":{"input_tokens":500,"output_tokens":200},"modelUsage":{"fake-claude-v1":{"input_tokens":500,"output_tokens":200}}}\n'
}

scenario_ai_verify_pass() {
  # Emits "PASS" verdict for ai_verify_plan() plan-level verification.
  default_exit=0
  printf '{"type":"system","subtype":"init","model":"fake-claude-v1"}\n'
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"PASS\\n"}]}}\n'
  printf '{"type":"result","total_cost_usd":0.005,"duration_ms":1000,"num_turns":1,"usage":{"input_tokens":300,"output_tokens":50},"modelUsage":{"fake-claude-v1":{"input_tokens":300,"output_tokens":50}}}\n'
}

scenario_ai_verify_fail() {
  # Emits "FAIL" verdict for ai_verify_plan() plan-level verification.
  default_exit=0
  printf '{"type":"system","subtype":"init","model":"fake-claude-v1"}\n'
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"FAIL\\nPhase 2 is missing the rate limiting requirement from the original plan. Phase 1 description was summarized instead of preserving original text.\\n"}]}}\n'
  printf '{"type":"result","total_cost_usd":0.005,"duration_ms":1000,"num_turns":1,"usage":{"input_tokens":300,"output_tokens":80},"modelUsage":{"fake-claude-v1":{"input_tokens":300,"output_tokens":80}}}\n'
}

scenario_success() {
  # Auto-detect prompt type and dispatch to appropriate response
  if is_ai_parse_prompt; then scenario_ai_parse; return; fi
  if is_verify_prompt; then scenario_ai_verify_pass; return; fi
  if is_phase_verify_prompt; then scenario_verify_pass; return; fi
  default_exit=0
  printf '{"type":"system","subtype":"init","model":"fake-claude-v1"}\n'
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"I will make the requested changes."}]}}\n'
  printf '{"type":"tool_use","name":"Edit","input":{"file_path":"/tmp/test.sh","new_string":"echo hello"},"id":"toolu_fake_001"}\n'
  printf '{"type":"tool_result","content":"ok","id":"toolu_fake_001"}\n'
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"Changes applied successfully.\\n"}]}}\n'
  printf '{"type":"result","total_cost_usd":0.01,"duration_ms":3000,"num_turns":2,"usage":{"input_tokens":500,"output_tokens":200},"modelUsage":{"fake-claude-v1":{"input_tokens":500,"output_tokens":200}}}\n'
}

