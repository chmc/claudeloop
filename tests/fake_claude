  printf '{"type":"assistant","message":{"content":[{"type":"tool_use","id":"toolu_er03","name":"Edit","input":{"file_path":"src/runner.sh","old_string":"execute_phase $p","new_string":"execute_phase \"$p\""}}]}}\n'
  printf '{"type":"user","message":{"content":[{"tool_use_id":"toolu_er03","type":"tool_result","content":"File edited successfully","is_error":false}]},"timestamp":"2026-01-01T12:00:02.500Z"}\n'
  printf '{"type":"assistant","message":{"content":[{"type":"tool_use","id":"toolu_er04","name":"Bash","input":{"command":"shellcheck -s sh src/runner.sh"}}]}}\n'
  printf '{"type":"user","message":{"content":[{"tool_use_id":"toolu_er04","type":"tool_result","content":"In src/runner.sh line 3:\\n  for p in $PHASES; do\\n         ^-- SC2086: Double quote to prevent globbing and word splitting.","is_error":true}]},"timestamp":"2026-01-01T12:00:05.100Z"}\n'
  printf '{"type":"assistant","message":{"content":[{"type":"tool_use","id":"toolu_er05","name":"Edit","input":{"file_path":"src/runner.sh","old_string":"for p in $PHASES","new_string":"for p in \"$PHASES\""}}]}}\n'
