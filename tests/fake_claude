  printf '{"type":"user","message":{"content":[{"tool_use_id":"toolu_er01","type":"tool_result","content":"#!/bin/sh\\nrun_phases() { for p in $PHASES; do execute_phase $p; done; }","is_error":false}]},"timestamp":"2026-01-01T12:00:01.000Z"}\n'
