  printf '{"type":"assistant","message":{"content":[{"type":"text","text":"Tests failed. Need to fix quoting and retry logic.\\n"}]}}\n'
  printf '{"type":"result","total_cost_usd":0.05,"duration_ms":15000,"num_turns":7,"usage":{"input_tokens":3200,"output_tokens":1100},"modelUsage":{"fake-claude-v1":{"input_tokens":3200,"output_tokens":1100}}}\n'
}

