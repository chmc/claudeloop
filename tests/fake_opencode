#!/bin/sh
# Fake OpenCode CLI for testing and verification.
# Emits OpenCode NDJSON events without API calls.
# Configuration via $FAKE_OPENCODE_DIR (required).
#
# Files:
#   scenario         - default scenario name (default: success)
#   scenarios        - per-call scenario (line N = call N, overrides default)
#   exit_codes       - per-call exit code (line N = call N)
#   call_count       - auto-incremented call counter
#   prompts/prompt_N - captured stdin for call N
#   args/args_N      - captured CLI args for call N
#   custom_output    - extra lines for custom scenario
#   custom_output_N  - per-call custom output
#
# Auto-detection: success, success_multi, and success_verbose scenarios
# auto-detect AI-parse and verification prompts from stdin content.
# AI-parse prompts (containing "plan extraction assistant") emit phase headers.
# Verification prompts (containing "verif") emit VERIFICATION_PASSED.

FAKE_OPENCODE_DIR="${FAKE_OPENCODE_DIR:?FAKE_OPENCODE_DIR must be set}"
FAKE_PROVIDER_DIR="$FAKE_OPENCODE_DIR"

# Source shared utilities
_script_dir="$(cd "$(dirname "$0")" && pwd)"
. "$_script_dir/lib/fake_provider_common.sh"

# --- Initialize ---
fake_provider_check_version "fake-opencode 0.0.0" "$@"
fake_provider_init
fake_provider_capture_prompt "plain"
fake_provider_capture_args "$@"
fake_provider_select_scenario

# --- Scenario functions ---
# Each emits NDJSON matching OpenCode's event format.

scenario_ai_parse() {
  default_exit=0
  printf '{"type":"session.created","sessionId":"sess_001","model":"fake-opencode-v1"}\n'
  printf '{"type":"message.part.updated","text":"## Phase 1: Setup\\nSet up the project structure and dependencies.\\n\\n## Phase 2: Implementation\\nImplement the core feature.\\n"}\n'
  printf '{"type":"session.idle","sessionId":"sess_001"}\n'
}

scenario_ai_verify_pass() {
  default_exit=0
  printf '{"type":"session.created","sessionId":"sess_001","model":"fake-opencode-v1"}\n'
  printf '{"type":"message.part.updated","text":"PASS\\n"}\n'
  printf '{"type":"session.idle","sessionId":"sess_001"}\n'
}

