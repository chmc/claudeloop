  default_exit=0
  printf '{"type":"session.created","sessionId":"sess_001","model":"fake-opencode-v1"}\n'
  printf '{"type":"message.part.updated","text":"FAIL\\nPhase 2 is missing the rate limiting requirement from the original plan. Phase 1 description was summarized instead of preserving original text.\\n"}\n'
  printf '{"type":"session.idle","sessionId":"sess_001"}\n'
}

scenario_success() {
  if is_ai_parse_prompt; then scenario_ai_parse; return; fi
  if is_verify_prompt; then scenario_ai_verify_pass; return; fi
  if is_phase_verify_prompt; then scenario_verify_pass; return; fi
  default_exit=0
  _write_fake_file "test.sh" "echo hello"
  printf '{"type":"session.created","sessionId":"sess_001","model":"fake-opencode-v1"}\n'
  printf '{"type":"message.part.updated","text":"I will make the requested changes."}\n'
  printf '{"type":"message.part.updated","callID":"tool_001","name":"Edit","state":"pending"}\n'
  printf '{"type":"message.part.updated","callID":"tool_001","name":"Edit","state":"completed","output":"ok"}\n'
  printf '{"type":"message.part.updated","text":"Changes applied successfully.\\n"}\n'
  printf '{"type":"session.idle","sessionId":"sess_001"}\n'
}

