# Verification manifest for demo-nudge.gif
# Extract frames after regeneration:
#
# dur=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 assets/demo-nudge.gif)
# ffmpeg -ss 3 -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-early.png
# ffmpeg -ss 7 -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-mid.png
# ffmpeg -sseof -0.5 -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-final.png
#
# Note: Nudge is injected via background file write (not interactive keystrokes).
# VHS pty does not route to /dev/tty, so sentinel keystroke detection doesn't work.
# Background job in hidden section writes .claudeloop/nudge-phase-2.md at t=5s.

frame@early (t~3s):
  - Phase 1 tool output (Bash mkdir, Write src/db.js)
  - "Phase 1 completed successfully"
  - "Executing Phase 2/2: Query Implementation (nudge active)" header in yellow

frame@mid (t~7s):
  - Phase 2 attempt 1: SQL injection test failures
  - "FAIL ✗ SQL injection vulnerability detected"
  - "Phase 2 failed" + "Retrying phase 2 after 3 seconds..."

final:
  - "Executing Phase 2/2: Query Implementation (nudge active)" (attempt 2)
  - "Switching to prepared statements as directed."
  - Bash npm test → "PASS ✓ all queries pass security checks"
  - "All phases completed!"
  - Session summary (model, cost, duration, tokens)
