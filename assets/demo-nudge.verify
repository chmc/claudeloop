# Verification manifest for demo-nudge.gif
# Extract frames after regeneration:
#
# dur=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 assets/demo-nudge.gif)
# ffmpeg -ss $(echo "$dur * 0.25" | bc) -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-25.png
# ffmpeg -ss $(echo "$dur * 0.50" | bc) -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-50.png
# ffmpeg -ss $(echo "$dur * 0.75" | bc) -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-75.png
# ffmpeg -sseof -0.5 -i assets/demo-nudge.gif -vframes 1 /tmp/nudge-final.png
#
# Note: Uses expect inside VHS to drive real interactive nudge flow.
# expect creates a pty where /dev/tty works; CLAUDECODE must be unset
# to prevent auto-YES_MODE (see demo-nudge.expect).

frame@early (t~25%):
  - Phase 1 tool output (Bash mkdir, Write src/db.js)
  - "Phase 1 completed successfully"
  - "Executing Phase 2/2: Query Implementation" header
  - "Type n to nudge" hint visible
  - SQL injection failure: "FAIL  ✗ SQL injection vulnerability detected"
  - "Press Enter to nudge (stops current attempt)" — nudge armed

frame@mid (t~50%):
  - "Stopped Phase 2" message
  - "nudge>" prompt with typed guidance
  - "use prepared statements for all DB queries"
  - "Nudge saved: use prepared statements for all DB queries"
  - "Retrying phase 2 after 1 seconds..."

frame@late (t~75%):
  - "Executing Phase 2/2: Query Implementation (nudge active)" header
  - "Switching to prepared statements as directed."
  - Write src/queries.js, Bash npm test
  - "PASS  ✓ all queries pass security checks"
  - "All phases completed!"
  - Session summary (model, cost, duration, tokens)

final:
  - Same as frame@late — still time showing completion state
