#!/bin/sh

# ClaudeLoop - Phase-by-Phase Execution Tool
# Executes multi-phase plans by spawning fresh Claude instances per phase

VERSION="0.29.0-beta.14"

set -eu

# Script directory
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

# Capture env vars before defaults (precedence: defaults → config → env → CLI)
_CL_PLAN_FILE="${PLAN_FILE:-}"
_CL_PROGRESS_FILE="${PROGRESS_FILE:-}"
_CL_MAX_RETRIES="${MAX_RETRIES:-}"
_CL_BASE_DELAY="${BASE_DELAY:-}"
_CL_SIMPLE_MODE="${SIMPLE_MODE:-}"
_CL_PHASE_PROMPT_FILE="${PHASE_PROMPT_FILE:-}"
_CL_QUOTA_RETRY_INTERVAL="${QUOTA_RETRY_INTERVAL:-}"
_CL_SKIP_PERMISSIONS="${SKIP_PERMISSIONS:-}"
_CL_STREAM_TRUNCATE_LEN="${STREAM_TRUNCATE_LEN:-}"
_CL_MAX_PHASE_TIME="${MAX_PHASE_TIME:-}"
_CL_IDLE_TIMEOUT="${IDLE_TIMEOUT:-}"
_CL_VERIFY_TIMEOUT="${VERIFY_TIMEOUT:-}"
_CL_VERIFY_IDLE_TIMEOUT="${VERIFY_IDLE_TIMEOUT:-}"
_CL_DEAD_TIMEOUT="${DEAD_TIMEOUT:-}"
_CL_VERIFY_PHASES="${VERIFY_PHASES:-}"
_CL_REFACTOR_PHASES="${REFACTOR_PHASES:-}"
_CL_REFACTOR_MAX_RETRIES="${REFACTOR_MAX_RETRIES:-}"
_CL_PROVIDER="${PROVIDER:-}"

# Source libraries
. "$SCRIPT_DIR/lib/parser.sh"
. "$SCRIPT_DIR/lib/phase_state.sh"
. "$SCRIPT_DIR/lib/dependencies.sh"
. "$SCRIPT_DIR/lib/progress.sh"
. "$SCRIPT_DIR/lib/plan_changes.sh"
. "$SCRIPT_DIR/lib/retry.sh"
. "$SCRIPT_DIR/lib/ui.sh"
. "$SCRIPT_DIR/lib/config.sh"
. "$SCRIPT_DIR/lib/wizard.sh"
. "$SCRIPT_DIR/lib/prompt.sh"
. "$SCRIPT_DIR/lib/stream_processor.sh"
. "$SCRIPT_DIR/lib/ai_parser.sh"
. "$SCRIPT_DIR/lib/permission_handler.sh"
. "$SCRIPT_DIR/lib/verify.sh"
. "$SCRIPT_DIR/lib/detectors.sh"
. "$SCRIPT_DIR/lib/refactor.sh"
. "$SCRIPT_DIR/lib/execution.sh"
. "$SCRIPT_DIR/lib/provider.sh"
. "$SCRIPT_DIR/lib/args.sh"
. "$SCRIPT_DIR/lib/archive.sh"
. "$SCRIPT_DIR/lib/recorder.sh"
. "$SCRIPT_DIR/lib/lessons.sh"
. "$SCRIPT_DIR/lib/setup.sh"
. "$SCRIPT_DIR/lib/orchestration.sh"
. "$SCRIPT_DIR/lib/state.sh"
. "$SCRIPT_DIR/lib/signals.sh"
. "$SCRIPT_DIR/lib/main_loop.sh"
. "$SCRIPT_DIR/lib/monitor.sh"

# Default configuration
PLAN_FILE="PLAN.md"
PROGRESS_FILE=".claudeloop/PROGRESS.md"
STATE_FILE=".claudeloop/state/current.json"
LOCK_FILE=".claudeloop/lock"
RESET_PROGRESS=false
START_PHASE=""
DRY_RUN=false
INTERRUPTED=false
FORCE_MODE=false
FORCE_KILLED=false
CURRENT_PHASE=""
PHASE_PROMPT_FILE=""
SIMPLE_MODE=false
VERBOSE_MODE=false
SKIP_PERMISSIONS=false
STREAM_TRUNCATE_LEN=300
HOOKS_ENABLED=false
LIVE_LOG=""
MONITOR_MODE=false
MAX_PHASE_TIME=900           # kill claude after N seconds per phase (0=disabled)
IDLE_TIMEOUT=600             # exit stream processor after N seconds of no activity (0=disabled)
DEAD_TIMEOUT=180             # exit if only heartbeats for N seconds (no real events, 0=disabled)
VERIFY_TIMEOUT=300           # kill verify_phase after N seconds (default 300)
VERIFY_IDLE_TIMEOUT=120      # idle detection in verify stream processor (0=disabled)
AI_PARSE=true
GRANULARITY="tasks"
NO_RETRY=false
AI_PARSE_FEEDBACK=false
VERIFY_PHASES=true
REFACTOR_PHASES=true
REFACTOR_MAX_RETRIES=20
PROVIDER=""                  # AI provider (claude, opencode; default: auto-detect)
_REFACTORING_PHASE=""
CURRENT_PIPELINE_PID=""     # PID of running claude pipeline (last in pipeline), for interrupt cleanup
CURRENT_PIPELINE_PGID=""    # PGID of running claude pipeline (first in pipeline), for group kill

# Sentinels: set to 1 when the corresponding arg is explicitly passed via CLI
_CLI_PLAN_FILE="" _CLI_PROGRESS_FILE="" _CLI_MAX_RETRIES="" _CLI_SIMPLE_MODE=""
_CLI_PHASE_PROMPT_FILE="" _CLI_QUOTA_RETRY_INTERVAL="" _CLI_SKIP_PERMISSIONS=""
_CLI_MAX_PHASE_TIME="" _CLI_IDLE_TIMEOUT="" _CLI_VERIFY_TIMEOUT="" _CLI_VERIFY_IDLE_TIMEOUT="" _CLI_DEAD_TIMEOUT=""
_CLI_AI_PARSE="" _CLI_GRANULARITY=""
_CLI_NO_RETRY="" _CLI_AI_PARSE_FEEDBACK=""
_CLI_VERIFY_PHASES=""
_CLI_REFACTOR_PHASES=""
_CLI_REFACTOR_MAX_RETRIES=""
_CLI_PROVIDER=""

# Set to 1 in tests to bypass [ -t 0 ] TTY check in run_setup_wizard
_WIZARD_FORCE="${_WIZARD_FORCE:-}"

# Session-level non-interactive mode: auto-answer all prompts (NOT persisted to conf)
YES_MODE="${YES_MODE:-false}"
RESUME_MODE=false
MARK_COMPLETE_PHASE=""
RECOVER_PROGRESS=false
ARCHIVE_MODE=false
LIST_ARCHIVES=false
RESTORE_ARCHIVE=""
REPLAY_MODE=false
REPLAY_ARCHIVE=""


# Main function
main() {
  trap handle_interrupt INT TERM
  trap cleanup EXIT

  apply_config_precedence "$@"

  # Validate flag combinations
  if [ "$DRY_RUN" = "true" ] && [ "$MONITOR_MODE" = "true" ]; then
    print_error "--dry-run and --monitor cannot be used together"
    exit 1
  fi

  print_logo

  # Monitor mode: follow live output of a running instance (never runs setup/execution)
  if [ "$MONITOR_MODE" = "true" ]; then
    run_monitor
    exit 0
  fi

  # Archive mode: archive current run and exit
  if [ "$ARCHIVE_MODE" = "true" ]; then
    archive_current_run
    exit 0
  fi

  # List archives mode
  if [ "$LIST_ARCHIVES" = "true" ]; then
    list_archives
    exit 0
  fi

  # Restore mode
  if [ -n "$RESTORE_ARCHIVE" ]; then
    restore_archive "$RESTORE_ARCHIVE"
    exit 0
  fi

  # Replay mode: regenerate replay HTML and exit
  if [ "$REPLAY_MODE" = "true" ]; then
    local replay_dir=".claudeloop"
    if [ -n "$REPLAY_ARCHIVE" ]; then
      replay_dir=".claudeloop/archive/$REPLAY_ARCHIVE"
      if [ ! -d "$replay_dir" ]; then
        print_error "Archive not found: $replay_dir"
        list_archives
        exit 1
      fi
    fi
    if [ ! -d "$replay_dir" ]; then
      print_error "No .claudeloop directory found"
      exit 1
    fi
    if [ ! -f "$replay_dir/PROGRESS.md" ]; then
      print_warning "No PROGRESS.md found in $replay_dir — report will be empty"
    fi
    _RECORDER_VERBOSE=true generate_replay "$replay_dir"
    if [ -f "$replay_dir/replay.html" ]; then
      print_success "Generated $replay_dir/replay.html"
    else
      print_error "Failed to generate replay.html"
      exit 1
    fi
    exit 0
  fi

  # Early provider validation (validate even in dry-run)
  if ! _provider=$(provider_detect); then
    exit 1
  fi

  # Early environment validation (git must exist before gitignore work)
  if ! $DRY_RUN; then
    if [ -f "$PROGRESS_FILE" ] && grep -q "Status: completed" "$PROGRESS_FILE" 2>/dev/null; then
      RESUME_MODE=true
    fi
    validate_environment
  fi

  _GITIGNORE_APPROVED=""
  run_setup_wizard
  [ -n "$_CL_VERIFY_PHASES" ]   && VERIFY_PHASES="$_CL_VERIFY_PHASES"
  [ -n "$_CL_REFACTOR_PHASES" ] && REFACTOR_PHASES="$_CL_REFACTOR_PHASES"
  write_config

  # Commit .gitignore if wizard or write_config modified it
  if ! $DRY_RUN; then
    commit_gitignore
  fi

  # --reset: clean all run state for a fresh start
  if $RESET_PROGRESS && ! $DRY_RUN; then
    if [ "$YES_MODE" != "true" ] && [ -t 0 ]; then
      print_warning "Reset will clear all run state (logs, config, progress) except archives."
      printf 'Continue? (y/N) '
      read -r _ans
      case "$_ans" in [yY]*) ;; *) print_error "Reset aborted"; exit 1 ;; esac
    fi
    clean_claudeloop_dir
    # Remove rotated logs (preserved by clean_claudeloop_dir for archive flow)
    rm -f .claudeloop/live-*.log
    # Prevent stale LIVE_LOG writes before init_live_log reinitializes
    LIVE_LOG=""
    # Fall back from deleted AI-parsed plan
    case "$PLAN_FILE" in
      .claudeloop/ai-parsed-plan.md) PLAN_FILE="PLAN.md" ;;
    esac
    log_ts "Run state cleared (--reset)"
    # Re-run wizard since conf was just deleted (fresh-start experience)
    run_setup_wizard
    write_config
    # Offer to exit now (non-interactive/YES_MODE auto-continues)
    if [ "$YES_MODE" != "true" ] && [ -t 0 ]; then
      printf 'Start fresh run? (Y/n) '
      read -r _ans
      case "$_ans" in [nN]*) log_ts "Exiting after reset"; exit 0 ;; esac
    fi
  fi

  init_live_log

  # Fall back from deleted AI-parsed plan to PLAN.md (global, not just --reset)
  if [ ! -f "$PLAN_FILE" ]; then
    case "$PLAN_FILE" in
      .claudeloop/ai-parsed-plan.md)
        if [ -f "PLAN.md" ]; then
          log_ts "ai-parsed-plan.md missing, falling back to PLAN.md"
          PLAN_FILE="PLAN.md"
        fi
        ;;
    esac
  fi

  # Validate plan and prompt files
  if [ ! -f "$PLAN_FILE" ] && ! { $RESET_PROGRESS && [ "$AI_PARSE" = "true" ]; }; then
    print_error "Plan file not found: $PLAN_FILE"
    exit 1
  fi
  if [ -n "$PHASE_PROMPT_FILE" ] && [ ! -r "$PHASE_PROMPT_FILE" ]; then
    print_error "Phase prompt file not found or not readable: $PHASE_PROMPT_FILE"
    exit 1
  fi

  # AI parsing and plan loading
  run_ai_parsing

  # Parse plan
  if [ "$_parse_msg" = "Parsing plan file" ]; then
    print_success "$_parse_msg: $PLAN_FILE"
  else
    printf '[%s] %s: %s\n' "$(date '+%H:%M:%S')" "$_parse_msg" "$PLAN_FILE"
    log_live "$_parse_msg: $PLAN_FILE"
  fi
  if ! parse_plan "$PLAN_FILE"; then
    print_error "Failed to parse plan file"
    exit 1
  fi

  printf '[%s] Found %s phases\n' "$(date '+%H:%M:%S')" "$PHASE_COUNT"
  log_live "Found $PHASE_COUNT phases"

  # Re-initialize live log after plan parsing (skip in dry-run)
  if ! $DRY_RUN; then
    init_live_log
  fi

  init_and_recover_progress
  apply_phase_overrides
  _PROGRESS_LOADED=true

  # Detect completed previous run and offer to archive
  _ARCHIVE_COMPLETED=false
  _ARCHIVE_DECLINED=false
  if ! $DRY_RUN && is_run_complete; then
    prompt_archive_completed_run --internal
    if [ "$_ARCHIVE_COMPLETED" = true ]; then
      LIVE_LOG=""
      init_live_log
      write_config
      write_progress "$PROGRESS_FILE" "$PLAN_FILE"
    fi
  fi

  # Print header and phase list
  print_header "$PLAN_FILE"
  echo ""
  print_all_phases

  if $DRY_RUN; then
    print_success "Dry run complete - plan is valid"
    exit 0
  fi

  print_warning "Press Ctrl+C at any time to stop (state will be saved)"
  echo ""

  # Resume any interrupted/pending refactors from previous run
  resume_pending_refactors

  # Initialize lessons capture for self-improvement mode
  lessons_init

  # Execute phases
  local exit_code=0
  main_loop || exit_code=$?

  write_progress "$PROGRESS_FILE" "$PLAN_FILE"
  [ $exit_code -eq 0 ] && clear_state

  # Auto-archive on successful completion
  _LAST_ARCHIVE_DIR=""
  if [ $exit_code -eq 0 ] && [ "${_CLAUDELOOP_NO_AUTO_ARCHIVE:-0}" != "1" ] \
     && [ "${_ARCHIVE_DECLINED:-}" != "true" ]; then
    archive_current_run --internal || print_warning "Auto-archive failed (non-fatal)"
  fi

  # Clear LIVE_LOG after archive (file was moved to archive dir)
  [ -n "${_LAST_ARCHIVE_DIR:-}" ] && LIVE_LOG=""

  echo ""
  if [ $exit_code -eq 0 ]; then
    _replay_path=""
    if [ -n "${_LAST_ARCHIVE_DIR:-}" ] && [ -f "$_LAST_ARCHIVE_DIR/replay.html" ]; then
      _replay_path="$_LAST_ARCHIVE_DIR/replay.html"
    elif [ -f ".claudeloop/replay.html" ]; then
      _replay_path=".claudeloop/replay.html"
    fi
    print_completion_summary "$PLAN_FILE" "$_replay_path"
  else
    print_header "$PLAN_FILE"
    print_all_phases
  fi

  exit $exit_code
}

# Run main (skip if script is sourced for testing)
if [ "${_CLAUDELOOP_SOURCE_ONLY:-0}" != "1" ]; then
  main "$@"
fi
