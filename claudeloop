_CL_PLAN_FILE="${PLAN_FILE:-}"
_CL_PROGRESS_FILE="${PROGRESS_FILE:-}"
_CL_MAX_RETRIES="${MAX_RETRIES:-}"
_CL_BASE_DELAY="${BASE_DELAY:-}"
