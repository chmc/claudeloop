STATE_FILE=".claudeloop/state/current.json"
LOCK_FILE=".claudeloop/lock"
RESET_PROGRESS=false
START_PHASE=""
DRY_RUN=false
INTERRUPTED=false
FORCE_MODE=false
FORCE_KILLED=false
CURRENT_PHASE=""
PHASE_PROMPT_FILE=""
SIMPLE_MODE=false
VERBOSE_MODE=false
SKIP_PERMISSIONS=false
STREAM_TRUNCATE_LEN=300
HOOKS_ENABLED=false
LIVE_LOG=""
MONITOR_MODE=false
MAX_PHASE_TIME=900           # kill claude after N seconds per phase (0=disabled)
IDLE_TIMEOUT=600             # exit stream processor after N seconds of no activity (0=disabled)
DEAD_TIMEOUT=180             # exit if only heartbeats for N seconds (no real events, 0=disabled)
